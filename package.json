{
  "name": "safe-markdown2html",
  "private": false,
  "type": "module",
  "version": "1.0.2",
  "description": "Convert Markdown to sanitized HTML with DOMPurify. Safe by default — prevents XSS and malformed markup.",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "browser": "dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "browser": "./dist/index.js",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "clean": "rimraf dist",
    "build": "npm run clean && rollup -c",
    "prepublishOnly": "npm run build",
    "preversion": "npm run build",
    "postversion": "git push --follow-tags",
    "release": "npm publish --access public",
    "release:patch": "npm version patch && npm publish --access public",
    "release:minor": "npm version minor && npm publish --access public",
    "release:major": "npm version major && npm publish --access public",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint ./src",
    "lint:fix": "eslint --fix ./src",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,css,md,mdx}\""
  },
  "author": "kimhongyeon",
  "license": "MIT",
  "dependencies": {
    "dompurify": "^3.4.0",
    "marked": "^18.0.2"
  },
  "peerDependencies": {
    "jsdom": ">=20.0.0"
  },
  "peerDependenciesMeta": {
    "jsdom": {
      "optional": true
    }
  },
  "devDependencies": {
    "jsdom": "^29.0.2",
    "@eslint/js": "^10.0.1",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^10.2.1",
    "eslint-plugin-unused-imports": "^4.4.1",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "rollup": "^4.60.2",
    "rollup-plugin-dts": "^6.4.1",
    "rollup-plugin-typescript2": "^0.37.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.58.2",
    "vitest": "^4.1.4"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/kimhongyeon/safe-markdown2html"
  },
  "bugs": {
    "url": "https://github.com/kimhongyeon/safe-markdown2html/issues"
  },
  "homepage": "https://github.com/kimhongyeon/safe-markdown2html",
  "keywords": [
    "markdown",
    "html",
    "sanitize",
    "xss",
    "dompurify",
    "marked",
    "converter",
    "safe",
    "security",
    "browser",
    "node",
    "isomorphic"
  ],
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public"
  }
}
